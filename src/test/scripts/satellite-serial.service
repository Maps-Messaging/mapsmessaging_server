[Unit]
Description=Virtual serial port pair (socat PTY bridge)
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/socat -d -d \
  pty,raw,echo=0,link=/dev/ttyV2,mode=0660,group=dialout \
  pty,raw,echo=0,link=/dev/ttyV3,mode=0660,group=dialout
Restart=on-failure
RestartSec=1
KillMode=process

[Install]
WantedBy=multi-user.target